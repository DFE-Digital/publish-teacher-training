<%= form_with url: request.path, method: :get, local: true, data: { controller: "course-filters" } do |form| %>
  <!-- STATUS filter -->
  <p class="govuk-heading-m">Filter courses</p>
  <!-- CLEAR FILTERS link -->
  <div class="govuk-body govuk-!-margin-bottom-5">
    <%= link_to "Clear all filters",
                request.path %>
  </div>
  <details class="app-c-filter-section" <%= "open" if params[:status].present? %>>
    <summary class="app-c-filter-section__summary">
      <h3 class="app-c-filter-section__summary-heading">
        Status
      </h3>
    </summary>
    <!-- STATUS filter -->
    <div class="app-c-filter-section__content">
      <%= form.govuk_check_boxes_fieldset :status,
      legend: nil,
      multiple: true do %>
        <div class="govuk-checkboxes govuk-checkboxes--small">
          <% %w[open closed draft rolled_over scheduled withdrawn].each do |status| %>
            <%= form.govuk_check_box :status, status,
            checked: Array(params[:status]).include?(status),
            label: { text: status.humanize } %>
          <% end %>
        </div>
      <% end %>
    </div>
  </details>
  <!-- EDUCATION PHASE filter -->
  <details class="app-c-filter-section" <%= "open" if params[:education_phase].present? %>>
    <summary class="app-c-filter-section__summary">
      <h3 class="app-c-filter-section__summary-heading">
        Education phase
      </h3>
    </summary>
    <div class="app-c-filter-section__content">
      <%= form.govuk_check_boxes_fieldset :education_phase,
      legend: nil,
      multiple: true do %>
        <div class="govuk-checkboxes govuk-checkboxes--small">
          <% %w[primary secondary further_education].each do |phase| %>
            <%= form.govuk_check_box :education_phase, phase,
            checked: Array(params[:education_phase]).include?(phase),
            label: { text: phase.humanize } %>
          <% end %>
        </div>
      <% end %>
    </div>
  </details>
  <!-- FEE OR SALARY PHASE filter -->
  <details class="app-c-filter-section" <%= "open" if params[:funding].present? %>>
    <summary class="app-c-filter-section__summary">
      <h3 class="app-c-filter-section__summary-heading">
        Fee or salary
      </h3>
    </summary>
    <div class="app-c-filter-section__content">
      <%= form.govuk_check_boxes_fieldset :funding,
      legend: nil,
      multiple: true do %>
        <div class="govuk-checkboxes govuk-checkboxes--small">
          <%= form.govuk_check_box :funding, "fee",
          checked: Array(params[:funding]).include?("fee"),
          label: { text: "Fee-paying" } %>
          <%= form.govuk_check_box :funding, "salary",
          checked: Array(params[:funding]).include?("salary"),
          label: { text: "Salary" } %>
          <%= form.govuk_check_box :funding, "apprenticeship",
          checked: Array(params[:funding]).include?("apprenticeship"),
          label: { text: "Apprenticeship" } %>
        </div>
      <% end %>
    </div>
  </details>
  <!-- QUALIFICATION filter -->
  <details class="app-c-filter-section " <%= "open" if params[:qualification].present? %>>
    <summary class="app-c-filter-section__summary">
      <h3 class="app-c-filter-section__summary-heading">
        Qualification
      </h3>
    </summary>
    <div class="app-c-filter-section__content">
      <%= form.govuk_check_boxes_fieldset :qualification,
      legend: nil,
      multiple: true do %>
        <div class="govuk-checkboxes govuk-checkboxes--small">
          <%= form.govuk_check_box :qualification, "qts",
          checked: Array(params[:qualification]).include?("qts"),
          label: { text: "QTS only" } %>
          <%= form.govuk_check_box :qualification, "pgce_with_qts",
          checked: Array(params[:qualification]).include?("pgce_with_qts"),
          label: { text: "QTS with PGCE or PGDE" } %>
        </div>
      <% end %>
    </div>
  </details>
  <!-- FULL TIME OR PART TIME filter -->
  <details class="app-c-filter-section" <%= "open" if params[:study_mode].present? %>>
    <summary class="app-c-filter-section__summary">
      <h3 class="app-c-filter-section__summary-heading">
        Full time or part time
      </h3>
    </summary>
    <div class="app-c-filter-section__content">
      <%= form.govuk_check_boxes_fieldset :study_mode,
      legend: nil,
      multiple: true do %>
        <div class="govuk-checkboxes govuk-checkboxes--small">
          <% %w[full_time part_time].each do |option| %>
            <%= form.govuk_check_box :study_mode, option,
            checked: Array(params[:study_mode]).include?(option),
            label: { text: option.humanize } %>
          <% end %>
        </div>
      <% end %>
    </div>
  </details>
  <!-- START DATE filter -->
  <!-- PLaceholder for now - doesn't work -->
  <details class="app-c-filter-section" <%= "open" if params[:start_date].present? %>>
    <summary class="app-c-filter-section__summary">
      <h3 class="app-c-filter-section__summary-heading">
        Start date
      </h3>
    </summary>
    <div class="app-c-filter-section__content">
      <%= form.govuk_check_boxes_fieldset :start_date,
      legend: nil,
      multiple: true do %>
        <div class="govuk-checkboxes govuk-checkboxes--small">
          <%= form.govuk_check_box :start_date, "jan_aug_2026",
          checked: Array(params[:start_date]).include?("jan_aug_2026"),
          label: { text: "January to August 2026" } %>
          <%= form.govuk_check_box :start_date, "sep_2026",
          checked: Array(params[:start_date]).include?("sep_2026"),
          label: { text: "September 2026 only" } %>
          <%= form.govuk_check_box :start_date, "oct_2026_jul_2027",
          checked: Array(params[:start_date]).include?("oct_2026_jul_2027"),
          label: { text: "October 2026 to July 2027" } %>
        </div>
      <% end %>
    </div>
  </details>
  <%= form.govuk_submit "Apply filters",
  class: "govuk-!-margin-top-4",
  data: { course_filters_target: "applyFiltersButton" } %>
<% end %>
