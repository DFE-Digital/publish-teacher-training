<% page_title = "Bulk update schools" %>
<% content_for :page_title, title_with_error_prefix("#{page_title} – #{course.name_and_code}", course.errors.any?) %>
<% content_for :before_content do %>
  <!-- Fix Back link to udpate placement schools page -->
  <%= govuk_back_link_to(
    schools_publish_provider_recruitment_cycle_course_path(course.provider_code, course.recruitment_cycle_year, course.course_code),
  ) %>
<% end %>
<div class="govuk-caption-l">
  <%= course.name_and_code %>
</div>
<div class="govuk-heading-l">
  Updating placement schools
</div>
<%# <p class="govuk-body">
  You are updating this information:
</p>
<ul class="govuk-list govuk-list--bullet">
  <li>Placement schools</li>
</ul> %>
<!-- Number of schools added or removed message -->
<!-- <% if @added_count.positive? || @removed_count.positive? %>
  <p class="govuk-body">
    <% parts = [] %>
    <% parts << "#{pluralize(@added_count, 'school')} added" if @added_count.positive? %>
    <% parts << "#{pluralize(@removed_count, 'school')} removed" if @removed_count.positive? %>
    <%= parts.join(' and ') %>.
  </p>
<% end %> -->
<!-- List of schools being added or removed -->
<p class="govuk-heading-m">
  You are updating these schools
</p>
<% if @added_schools.empty? && @removed_schools.empty? %>
  <p class="govuk-body">
    No placement schools added or removed.
  </p>
<% else %>
  <% if @added_schools.any? %>
    <p class="govuk-body govuk-!-margin-bottom-1">
      <strong>You are adding <%= pluralize(@added_schools.size, "school") %>:</strong>
    </p>
    <ul class="govuk-list govuk-list--bullet">
      <% @added_schools.each do |school| %>
        <li><%= school.location_name %></li>
      <% end %>
    </ul>
  <% end %>
  <% if @removed_schools.any? %>
    <p class="govuk-body govuk-!-margin-bottom-1">
      <strong>You are removing <%= pluralize(@removed_schools.size, "school") %>:</strong>
    </p>
    <ul class="govuk-list govuk-list--bullet">
      <% @removed_schools.each do |school| %>
        <li><%= school.location_name %></li>
      <% end %>
    </ul>
  <% end %>
<% end %>
<br>
<%= form_with(
  url: edit_bulk_schools_publish_provider_recruitment_cycle_course_path,
  method: :post
) do |f| %>
  <!-- Hidden fields to pass the updated school information -->
  <%= hidden_field_tag :added_count, @added_count %>
  <%= hidden_field_tag :removed_count, @removed_count %>
  <% @added_site_ids.each do |id| %>
    <%= hidden_field_tag "added_site_ids[]", id %>
  <% end %>
  <% @removed_site_ids.each do |id| %>
    <%= hidden_field_tag "removed_site_ids[]", id %>
  <% end %>
  <%= f.govuk_radio_buttons_fieldset :bulk_apply,
    legend: {
      text: "What courses do you want to apply this change to?",
      size: "m",
    } do %>
    <% @bulk_options.each do |option| %>
      <%= f.govuk_radio_button(
        :bulk_apply,
        option.id,
        label: { text: option.name }
      ) %>
    <% end %>
    <div class="govuk-radios__divider">
      or
    </div>
    <%= f.govuk_radio_button(
      :bulk_apply,
      @this_course_option.id,
      label: { text: @this_course_option.name }
    ) %>
  <% end %>
  <%= f.govuk_submit "Continue to view the courses that will be updated" %>
<% end %>
