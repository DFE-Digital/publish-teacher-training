  <%# <div class="govuk-grid-column-two-thirds"> %>
<table class="govuk-table app-table--vertical-align-top app-table--courses">
  <thead class="govuk-table__head">
    <tr class="govuk-table__row">
      <th class="govuk-table__header"><%= t(".course") %></th>
      <% if @show_course_info_column %>
        <th class="govuk-table__header">Course information</th>
      <% end %>
      <th class="govuk-table__header">Status</th>
    </tr>
  </thead>
  <tbody class="govuk-table__body">
    <%= render partial: "publish/courses/course_table_row", collection: courses, as: :course %>
  </tbody>
</table>
<%# </div> %>
