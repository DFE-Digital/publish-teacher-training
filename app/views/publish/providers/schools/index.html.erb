<% content_for :page_title, t(".title") %>
<%= content_for :before_content, render_breadcrumbs(:sites) %>
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <%= render Publish::SchoolsChangedBannerComponent.new(provider: @provider) %>
    <h1 class="govuk-heading-l">
      <%= t(".title") %>
    </h1>
    <div class="govuk-button-group">
      <%= govuk_button_link_to t(".add_school"),
            search_publish_provider_recruitment_cycle_schools_path(@provider.provider_code) %>
      <%= govuk_link_to(
            "Add multiple schools",
            new_publish_provider_recruitment_cycle_schools_multiple_path,
            class: "govuk-button govuk-button--secondary govuk"
          ) %>
    </div>
    <p class="govuk-body">
      You can only add schools that are on
      <%= govuk_link_to(
            "Get Information About Schools (GIAS)",
            "https://get-information-schools.service.gov.uk/"
          ) %>.
    </p>
    <!-- SEARCH BOX -->
    <div>
      <div class="school-search-container">
        <div class="school-search-content">
          <div class="govuk-form-group">
            <p class="govuk-heading-m">
              Search for a school in the list
            </p>
            <label class="govuk-label" for="school-search">
              Enter the name of a school, university or college.
              You can also enter a postcode or URN.
            </label>
            <%= form_with url: publish_provider_recruitment_cycle_schools_path(@provider.provider_code),
                          method: :get,
                          local: true do %>
              <%= text_field_tag :query,
                    params[:query],
                    id: "school-search",
                    class: "govuk-input",
                    placeholder: "Enter school name, postcode or URN" %>
              <div class="govuk-button-group govuk-!-margin-top-2">
                <%= submit_tag "Search", class: "govuk-button" %>
                <!-- Clear search -->
                <%= link_to "Clear search",
                      publish_provider_recruitment_cycle_schools_path(@provider.provider_code),
                      class: "govuk-link" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
      <!-- SHOW SEARCH TERM - do we want this? -->
      <% if params[:query].present? %>
        <p class="govuk-body">
          Showing results for "<strong><%= params[:query] %></strong>"
        </p>
      <% end %>
      <!-- NO RESULTS MESSAGE -->
      <% if params[:query].present? && @schools.empty? %>
        <div class="govuk-body govuk-!-margin-top-3">
          No schools found with that search.
          <%= link_to "View all schools",
                publish_provider_recruitment_cycle_schools_path(@provider.provider_code),
                class: "govuk-link" %>
        </div>
      <% end %>
      <!-- TABLE OF SCHOOLS -->
      <% if @schools.any? %>
        <div>
          <table class="govuk-table">
            <thead class="govuk-table__head">
              <tr class="govuk-table__row">
                <th class="govuk-table__header" scope="col">
                  <%= t(".name") %>
                </th>
                <th class="govuk-table__header" scope="col">
                  Remove school
                </th>
              </tr>
            </thead>
            <tbody class="govuk-table__body">
              <%= render partial: "school", collection: @schools %>
            </tbody>
          </table>
        </div>
        <div>
          <%= govuk_pagination(pagy: @pagy) %>
        </div>
      <% end %>
    </div>
    <%= render Shared::AdviceComponent::View.new(title: "Attaching schools to courses") do %>
      <%= render Publish::Providers::SchoolPlacements::OutcomeExplainerComponent.new(
        recruitment_cycle: @recruitment_cycle,
        provider: @provider,
      ) %>
    <% end %>
  </div>
</div>
