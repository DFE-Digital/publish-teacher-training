<%= render PageTitle.new(title: t(".title", count: @feedbacks.count)) %>

<% content_for :before_content do %>
  <%= govuk_back_link_to(support_feedback_index_path) %>
<% end %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">
    <h1 class="govuk-heading-l">
      <%= t(".title", count: @feedbacks.count) %>
    </h1>

    <%= form_with url: delete_multiple_support_feedback_index_path, method: :delete, data: { turbo: false } do |f| %>
      <% @feedbacks.each do |feedback| %>
        <%= hidden_field_tag "feedback_ids[]", feedback.id %>
      <% end %>

      <%= f.govuk_submit t(".confirm_delete"), class: "govuk-button--warning" %>
    <% end %>

    <p class="govuk-body">
      <%= govuk_link_to(t(".cancel_link"), support_feedback_index_path) %>
    </p>
  </div>
</div>
