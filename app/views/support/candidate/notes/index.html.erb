<%= render PageTitle.new(title: "support.candidates.notes") %>

<% content_for :before_content do %>
  <%= govuk_back_link_to(support_candidates_path(page: params[:page])) %>
<% end %>

<h1 class="govuk-heading-l"><%= @candidate.email_address %></h1>

<%= render "support/candidate/tabs", candidate: @candidate, current_tab: :notes %>

<% if @notes.present? %>
  <%= govuk_table do |table| %>
    <% table.with_head do |head| %>
      <% head.with_row do |row| %>
        <% row.with_cell text: t("support.candidates.notes.course") %>
        <% row.with_cell text: t("support.candidates.notes.provider") %>
        <% row.with_cell text: t("support.candidates.notes.note") %>
        <% row.with_cell text: t("support.candidates.notes.updated_at") %>
      <% end %>
    <% end %>
    <% table.with_body do |body| %>
      <% @notes.each do |saved| %>
        <% course = saved.course %>
        <% body.with_row do |row| %>
          <% row.with_cell text: govuk_link_to(course.name_and_code, publish_provider_recruitment_cycle_course_url(course.provider.provider_code, course.provider.recruitment_cycle_year, course.course_code)) %>
          <% row.with_cell text: govuk_link_to(course.provider.provider_name, support_recruitment_cycle_provider_path(course.provider.recruitment_cycle_year, course.provider)) %>
          <% row.with_cell text: saved.note %>
          <% row.with_cell text: saved.updated_at.to_fs(:govuk_date_and_time) %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% else %>
  <p class="govuk-body"><%= t("support.candidates.notes.no_notes") %></p>
<% end %>
