<div class="app-active-filters">
  <div class="app-active-filters__header">
    <h3 class="govuk-heading-s app-active-filters__heading">Active filters</h3>
    <p class="govuk-body">
      <%= render Find::Courses::ClearAllFilters::View.new(active_filters:, position: :top) %>
    </p>
  </div>
  <ul class="app-active-filters__remove-filters">
    <% active_filters.each do |filter| %>
      <li>
        <%= govuk_link_to(
            content_tag(:span, class: "app-active-filters__remove-filter-text") do
              concat content_tag(:span, "Remove filter", class: "govuk-visually-hidden")
              concat filter.formatted_value
            end,
            find_results_path(search_params.merge(filter.remove_params)),
            class: "app-active-filters__remove-filter",
          ) %>
      </li>
    <% end %>
  </ul>
</div>
